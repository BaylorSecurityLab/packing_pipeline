+void plugin_mem_buffer_free(struct qemu_plugin_mem_buffer *buffer)
+{
+    if (!buffer) {
+        return;
+    }
+    QLIST_REMOVE_RCU(buffer, entry);
+    plugin_scoreboard_free(buffer->score);
+    g_free(buffer);
+}
