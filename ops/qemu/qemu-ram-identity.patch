+QEMU_DISABLE_CFI
+void qemu_plugin_flush_mem_buffers(CPUState *cpu)
+{
+    struct qemu_plugin_mem_buffer *buffer, *next;
+
+    QLIST_FOREACH_SAFE_RCU(buffer, &plugin.mem_buffers, entry, next) {
+        char *element = buffer->score->data->data +
+            cpu->cpu_index * g_array_get_element_size(buffer->score->data);
+        uint64_t *count = (uint64_t *)element;
+        uint64_t retained = MIN(*count, buffer->capacity);
+        struct qemu_plugin_mem_buffer_entry *events =
+            (struct qemu_plugin_mem_buffer_entry *)(element + sizeof(*count));
+
+        if (*count > buffer->capacity) {
+            qatomic_inc(&buffer->overflows);
+        }
+        for (uint64_t index = 0; index < retained; index++) {
+            qemu_plugin_vcpu_mem_cb_t cb =
+                (qemu_plugin_vcpu_mem_cb_t)(uintptr_t)events[index].callback;
+            qemu_plugin_set_cb_flags(cpu, events[index].cb_flags);
+            cb(cpu->cpu_index, events[index].meminfo,
+               events[index].vaddr,
+               (void *)(uintptr_t)events[index].userp);
+        }
+        *count = 0;
+    }
+    qemu_plugin_set_cb_flags(cpu, QEMU_PLUGIN_CB_NO_REGS);
+}
