+static bool plugin_cond_matches(enum qemu_plugin_cond cond,
+                                qemu_plugin_u64 entry, uint64_t imm,
+                                int cpu_index)
+{
+    char *ptr = entry.score->data->data;
+    size_t elem_size = g_array_get_element_size(entry.score->data);
+    uint64_t val = *(uint64_t *)(ptr + entry.offset +
+                                cpu_index * elem_size);
+
+    switch (cond) {
+    case QEMU_PLUGIN_COND_EQ:
+        return val == imm;
+    case QEMU_PLUGIN_COND_NE:
+        return val != imm;
+    case QEMU_PLUGIN_COND_LT:
+        return val < imm;
+    case QEMU_PLUGIN_COND_LE:
+        return val <= imm;
+    case QEMU_PLUGIN_COND_GT:
+        return val > imm;
+    case QEMU_PLUGIN_COND_GE:
+        return val >= imm;
+    case QEMU_PLUGIN_COND_ALWAYS:
+        return true;
+    case QEMU_PLUGIN_COND_NEVER:
+        return false;
+    default:
+        g_assert_not_reached();
+    }
+}
+
+static void plugin_mem_buffer_append(
+    struct qemu_plugin_buffered_mem_cb *cb, int cpu_index,
+    qemu_plugin_meminfo_t meminfo, uint64_t vaddr)
+{
+    char *element;
+    uint64_t *count;
+    size_t slot;
+    struct qemu_plugin_mem_buffer_entry *events;
+
+    if (!plugin_cond_matches(cb->cond, cb->entry, cb->imm, cpu_index)) {
+        return;
+    }
+    element = cb->buffer->score->data->data +
+              cpu_index * g_array_get_element_size(cb->buffer->score->data);
+    count = (uint64_t *)element;
+    slot = MIN(*count, cb->buffer->capacity);
+    events = (struct qemu_plugin_mem_buffer_entry *)(element +
+                                                     sizeof(*count));
+    events[slot] = (struct qemu_plugin_mem_buffer_entry){
+        .vaddr = vaddr,
+        .callback = (uintptr_t)cb->f.vcpu_mem,
+        .userp = (uintptr_t)cb->userp,
+        .meminfo = meminfo,
+        .cb_flags = tcg_call_to_qemu_plugin_cb_flags(cb->info->flags),
+    };
+    if (*count <= cb->buffer->capacity) {
+        (*count)++;
+    }
+}
