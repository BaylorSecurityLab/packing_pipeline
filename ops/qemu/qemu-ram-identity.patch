+struct qemu_plugin_mem_buffer *plugin_mem_buffer_new(size_t capacity)
+{
+    struct qemu_plugin_mem_buffer *buffer;
+    size_t element_size;
+
+    g_return_val_if_fail(capacity > 0, NULL);
+    g_return_val_if_fail(capacity <
+                         (SIZE_MAX - sizeof(uint64_t)) /
+                         sizeof(struct qemu_plugin_mem_buffer_entry), NULL);
+    element_size = sizeof(uint64_t) +
+                   (capacity + 1) *
+                   sizeof(struct qemu_plugin_mem_buffer_entry);
+    buffer = g_new0(struct qemu_plugin_mem_buffer, 1);
+    buffer->capacity = capacity;
+    buffer->score = plugin_scoreboard_new(element_size);
+    QLIST_INSERT_HEAD_RCU(&plugin.mem_buffers, buffer, entry);
+    return buffer;
+}
