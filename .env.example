# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored (.gitignore line 5) — never commit real credentials.
#
# Consumed by empirical_types/nas.py via os.environ. Load before running any
# packer-types NAS command:
#
#   set -a && source .env && set +a
#   uv run packer-types stage-nas --destination /data/packer-samples
#
PACKER_NAS_USERNAME=your-nas-username
PACKER_NAS_PASSWORD=your-nas-password

# Server and share default in the CLI to --server 10.100.99.29 --share samples.
# The code does not read these; shown for reference / documentation only.
#   NAS_SERVER=10.100.99.29
#   NAS_SHARE=samples
